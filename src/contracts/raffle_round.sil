        });
    }

    #[covenant.singleton(mode = transition, termination = allowed)]
    function finalize(
        State prev_state,
        State[] next_states,
        byte[32] creator_secret,
        int winner_ticket_id,
        byte[35] winner_script_pub_key
    ) : (State[]) {
        require(prev_state.status == 1);
        require(next_states.length == 0);
        require(prev_state.sold_tickets >= prev_state.min_tickets);

        byte[32] round_id_bytes =
            byte[1](byte(prev_state.round_id_00)) +
            byte[1](byte(prev_state.round_id_01)) +
            byte[1](byte(prev_state.round_id_02)) +
            byte[1](byte(prev_state.round_id_03)) +
            byte[1](byte(prev_state.round_id_04)) +
            byte[1](byte(prev_state.round_id_05)) +
            byte[1](byte(prev_state.round_id_06)) +
            byte[1](byte(prev_state.round_id_07)) +
            byte[1](byte(prev_state.round_id_08)) +
            byte[1](byte(prev_state.round_id_09)) +
            byte[1](byte(prev_state.round_id_10)) +
            byte[1](byte(prev_state.round_id_11)) +
            byte[1](byte(prev_state.round_id_12)) +
            byte[1](byte(prev_state.round_id_13)) +
            byte[1](byte(prev_state.round_id_14)) +
            byte[1](byte(prev_state.round_id_15)) +
            byte[1](byte(prev_state.round_id_16)) +
            byte[1](byte(prev_state.round_id_17)) +
            byte[1](byte(prev_state.round_id_18)) +
            byte[1](byte(prev_state.round_id_19)) +
            byte[1](byte(prev_state.round_id_20)) +
            byte[1](byte(prev_state.round_id_21)) +
            byte[1](byte(prev_state.round_id_22)) +
            byte[1](byte(prev_state.round_id_23)) +
            byte[1](byte(prev_state.round_id_24)) +
            byte[1](byte(prev_state.round_id_25)) +
            byte[1](byte(prev_state.round_id_26)) +
            byte[1](byte(prev_state.round_id_27)) +
            byte[1](byte(prev_state.round_id_28)) +
            byte[1](byte(prev_state.round_id_29)) +
            byte[1](byte(prev_state.round_id_30)) +
            byte[1](byte(prev_state.round_id_31));
        byte[32] creator_commitment_bytes =
            byte[1](byte(prev_state.creator_commitment_00)) +
            byte[1](byte(prev_state.creator_commitment_01)) +
            byte[1](byte(prev_state.creator_commitment_02)) +
            byte[1](byte(prev_state.creator_commitment_03)) +
            byte[1](byte(prev_state.creator_commitment_04)) +
            byte[1](byte(prev_state.creator_commitment_05)) +
            byte[1](byte(prev_state.creator_commitment_06)) +
            byte[1](byte(prev_state.creator_commitment_07)) +
            byte[1](byte(prev_state.creator_commitment_08)) +
            byte[1](byte(prev_state.creator_commitment_09)) +
            byte[1](byte(prev_state.creator_commitment_10)) +
            byte[1](byte(prev_state.creator_commitment_11)) +
            byte[1](byte(prev_state.creator_commitment_12)) +
            byte[1](byte(prev_state.creator_commitment_13)) +
            byte[1](byte(prev_state.creator_commitment_14)) +
            byte[1](byte(prev_state.creator_commitment_15)) +
            byte[1](byte(prev_state.creator_commitment_16)) +
            byte[1](byte(prev_state.creator_commitment_17)) +
            byte[1](byte(prev_state.creator_commitment_18)) +
            byte[1](byte(prev_state.creator_commitment_19)) +
            byte[1](byte(prev_state.creator_commitment_20)) +
            byte[1](byte(prev_state.creator_commitment_21)) +
            byte[1](byte(prev_state.creator_commitment_22)) +
            byte[1](byte(prev_state.creator_commitment_23)) +
            byte[1](byte(prev_state.creator_commitment_24)) +
            byte[1](byte(prev_state.creator_commitment_25)) +
            byte[1](byte(prev_state.creator_commitment_26)) +
            byte[1](byte(prev_state.creator_commitment_27)) +
            byte[1](byte(prev_state.creator_commitment_28)) +
            byte[1](byte(prev_state.creator_commitment_29)) +
            byte[1](byte(prev_state.creator_commitment_30)) +
            byte[1](byte(prev_state.creator_commitment_31));
        byte[32] ticket_root_bytes =
            byte[1](byte(prev_state.ticket_root_00)) +
            byte[1](byte(prev_state.ticket_root_01)) +
            byte[1](byte(prev_state.ticket_root_02)) +
            byte[1](byte(prev_state.ticket_root_03)) +
            byte[1](byte(prev_state.ticket_root_04)) +
            byte[1](byte(prev_state.ticket_root_05)) +
            byte[1](byte(prev_state.ticket_root_06)) +
            byte[1](byte(prev_state.ticket_root_07)) +
            byte[1](byte(prev_state.ticket_root_08)) +
            byte[1](byte(prev_state.ticket_root_09)) +
            byte[1](byte(prev_state.ticket_root_10)) +
            byte[1](byte(prev_state.ticket_root_11)) +
            byte[1](byte(prev_state.ticket_root_12)) +
            byte[1](byte(prev_state.ticket_root_13)) +
            byte[1](byte(prev_state.ticket_root_14)) +
            byte[1](byte(prev_state.ticket_root_15)) +
            byte[1](byte(prev_state.ticket_root_16)) +
            byte[1](byte(prev_state.ticket_root_17)) +
            byte[1](byte(prev_state.ticket_root_18)) +
            byte[1](byte(prev_state.ticket_root_19)) +
            byte[1](byte(prev_state.ticket_root_20)) +
            byte[1](byte(prev_state.ticket_root_21)) +
            byte[1](byte(prev_state.ticket_root_22)) +
            byte[1](byte(prev_state.ticket_root_23)) +
            byte[1](byte(prev_state.ticket_root_24)) +
            byte[1](byte(prev_state.ticket_root_25)) +
            byte[1](byte(prev_state.ticket_root_26)) +
            byte[1](byte(prev_state.ticket_root_27)) +
            byte[1](byte(prev_state.ticket_root_28)) +
            byte[1](byte(prev_state.ticket_root_29)) +
            byte[1](byte(prev_state.ticket_root_30)) +
            byte[1](byte(prev_state.ticket_root_31));

        require(sha256(byte[](creator_secret)) == creator_commitment_bytes);

        byte[32] seed = sha256(byte[](round_id_bytes) + byte[](ticket_root_bytes) + byte[](creator_secret));
        require(winner_ticket_id == int(seed) % prev_state.sold_tickets);

        require(tx.outputs[0].scriptPubKey == byte[](winner_script_pub_key));
        require(tx.outputs[0].value == prev_state.pot_amount);

        return(next_states);
    }

    #[covenant.singleton(mode = transition)]
    function enter_refunding(State prev_state) : (State) {
        require(prev_state.status == 0 || prev_state.status == 1);
        require(prev_state.sold_tickets < prev_state.min_tickets);

        return({
            max_tickets: prev_state.max_tickets,
            min_tickets: prev_state.min_tickets,
