            creator_commitment_20: prev_state.creator_commitment_20,
            creator_commitment_21: prev_state.creator_commitment_21,
            creator_commitment_22: prev_state.creator_commitment_22,
            creator_commitment_23: prev_state.creator_commitment_23,
            creator_commitment_24: prev_state.creator_commitment_24,
            creator_commitment_25: prev_state.creator_commitment_25,
            creator_commitment_26: prev_state.creator_commitment_26,
            creator_commitment_27: prev_state.creator_commitment_27,
            creator_commitment_28: prev_state.creator_commitment_28,
            creator_commitment_29: prev_state.creator_commitment_29,
            creator_commitment_30: prev_state.creator_commitment_30,
            creator_commitment_31: prev_state.creator_commitment_31,
            fee_bps: prev_state.fee_bps,
            sold_tickets: prev_state.sold_tickets + 1,
            pot_amount: prev_state.pot_amount + prev_state.ticket_price,
            status: 0,
            ticket_root_00: int(next_ticket_root[0]),
            ticket_root_01: int(next_ticket_root[1]),
            ticket_root_02: int(next_ticket_root[2]),
            ticket_root_03: int(next_ticket_root[3]),
            ticket_root_04: int(next_ticket_root[4]),
            ticket_root_05: int(next_ticket_root[5]),
            ticket_root_06: int(next_ticket_root[6]),
            ticket_root_07: int(next_ticket_root[7]),
            ticket_root_08: int(next_ticket_root[8]),
