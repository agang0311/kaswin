            ticket_root_10: int(next_ticket_root[10]),
            ticket_root_11: int(next_ticket_root[11]),
            ticket_root_12: int(next_ticket_root[12]),
            ticket_root_13: int(next_ticket_root[13]),
            ticket_root_14: int(next_ticket_root[14]),
            ticket_root_15: int(next_ticket_root[15]),
            ticket_root_16: int(next_ticket_root[16]),
            ticket_root_17: int(next_ticket_root[17]),
            ticket_root_18: int(next_ticket_root[18]),
