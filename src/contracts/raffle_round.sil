pragma silverscript ^0.1.0;

// Kaspa Raffle Static V0 covenant draft.
//
// Toccata's current validateOutputState path accepts primitive state fields, but
// not byte arrays. 32-byte values are encoded as 32 int byte slots and rebuilt
// as byte[32] values only inside the script when hashing is needed.

