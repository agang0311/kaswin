            creator_commitment_26: prev_state.creator_commitment_26,
            creator_commitment_27: prev_state.creator_commitment_27,
            creator_commitment_28: prev_state.creator_commitment_28,
            creator_commitment_29: prev_state.creator_commitment_29,
            creator_commitment_30: prev_state.creator_commitment_30,
            creator_commitment_31: prev_state.creator_commitment_31,
            fee_bps: prev_state.fee_bps,
            sold_tickets: prev_state.sold_tickets,
            pot_amount: prev_state.pot_amount,
            status: 1,
            ticket_root_00: prev_state.ticket_root_00,
            ticket_root_01: prev_state.ticket_root_01,
            ticket_root_02: prev_state.ticket_root_02,
            ticket_root_03: prev_state.ticket_root_03,
            ticket_root_04: prev_state.ticket_root_04,
