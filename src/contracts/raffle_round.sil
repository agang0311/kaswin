            ticket_root_30: int(next_ticket_root[30]),
            ticket_root_31: int(next_ticket_root[31]),
        });
    }

    #[covenant.singleton(mode = transition)]
    function close(State prev_state) : (State) {
        require(prev_state.status == 0);
        require(prev_state.sold_tickets == prev_state.max_tickets || prev_state.sold_tickets >= prev_state.min_tickets);

        return({
            max_tickets: prev_state.max_tickets,
            min_tickets: prev_state.min_tickets,
            ticket_price: prev_state.ticket_price,
            round_id_00: prev_state.round_id_00,
            round_id_01: prev_state.round_id_01,
            round_id_02: prev_state.round_id_02,
            round_id_03: prev_state.round_id_03,
            round_id_04: prev_state.round_id_04,
            round_id_05: prev_state.round_id_05,
            round_id_06: prev_state.round_id_06,
            round_id_07: prev_state.round_id_07,
            round_id_08: prev_state.round_id_08,
            round_id_09: prev_state.round_id_09,
            round_id_10: prev_state.round_id_10,
            round_id_11: prev_state.round_id_11,
            round_id_12: prev_state.round_id_12,
            round_id_13: prev_state.round_id_13,
            round_id_14: prev_state.round_id_14,
            round_id_15: prev_state.round_id_15,
            round_id_16: prev_state.round_id_16,
            round_id_17: prev_state.round_id_17,
            round_id_18: prev_state.round_id_18,
            round_id_19: prev_state.round_id_19,
            round_id_20: prev_state.round_id_20,
            round_id_21: prev_state.round_id_21,
            round_id_22: prev_state.round_id_22,
            round_id_23: prev_state.round_id_23,
            round_id_24: prev_state.round_id_24,
            round_id_25: prev_state.round_id_25,
            round_id_26: prev_state.round_id_26,
            round_id_27: prev_state.round_id_27,
            round_id_28: prev_state.round_id_28,
            round_id_29: prev_state.round_id_29,
            round_id_30: prev_state.round_id_30,
            round_id_31: prev_state.round_id_31,
            creator_commitment_00: prev_state.creator_commitment_00,
            creator_commitment_01: prev_state.creator_commitment_01,
            creator_commitment_02: prev_state.creator_commitment_02,
            creator_commitment_03: prev_state.creator_commitment_03,
            creator_commitment_04: prev_state.creator_commitment_04,
            creator_commitment_05: prev_state.creator_commitment_05,
            creator_commitment_06: prev_state.creator_commitment_06,
            creator_commitment_07: prev_state.creator_commitment_07,
            creator_commitment_08: prev_state.creator_commitment_08,
            creator_commitment_09: prev_state.creator_commitment_09,
            creator_commitment_10: prev_state.creator_commitment_10,
            creator_commitment_11: prev_state.creator_commitment_11,
            creator_commitment_12: prev_state.creator_commitment_12,
            creator_commitment_13: prev_state.creator_commitment_13,
